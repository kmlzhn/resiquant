# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real secrets.

# Required: Perplexity API key (get one at https://www.perplexity.ai → API → Keys)
PERPLEXITY_API_KEY=pplx-your-key-here

# Optional: Perplexity model (default: sonar-pro)
# PERPLEXITY_MODEL=sonar-pro

# Optional: LLM request timeout in seconds (default: 30)
# LLM_TIMEOUT_SECONDS=30

# Optional: Directory for file-based extraction cache (default: cache/)
# CACHE_DIR=cache
